# PolicyDiff API Configuration Template
# Copy this file to .env.config and fill in the values.

# Server Configuration
PORT=3000
NODE_ENV=development # development | production | test
LOG_LEVEL=debug      # debug | info | warn | error

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/policydiff

# Security
# In production, API_SECRET must be at least 32 characters long.
API_SECRET=your-32-character-secret-goes-here
INTERNAL_METRICS_TOKEN=dev-metrics-token

# Rate Limiting
GLOBAL_RATE_LIMIT=1000
PER_KEY_RATE_LIMIT=100
